# Under-65 CMS Marketplace API
MARKETPLACE_API_KEY=

# Medicare Concierge service credentials
CONCIERGE_EMAIL=
CONCIERGE_PASSWORD=

# Vercel Blob — for Medicare Summary of Benefits PDFs.
# Only needed on the machine that runs scripts/upload-sobs.js.
# Production reads are public; no token required at runtime.
BLOB_READ_WRITE_TOKEN=

# Feature flags
LIFE_API_ENABLED=false
