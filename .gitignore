# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# CMS individual plan files (bundled into extracted_cms.json.gz)
/data/extracted_cms/

# vercel
.vercel

# large data files
data/cms_benefits.db

# superpowers
.superpowers/

# typescript
*.tsbuildinfo
next-env.d.ts
